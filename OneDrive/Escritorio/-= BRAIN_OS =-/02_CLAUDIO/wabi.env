# wabi.env - configuración activa Wabi-Sabi (NO commitear)
# Generado automaticamente. Editar manualmente para agregar Kimi/GLM.
# REEMPLAZAR TODOS LOS PLACEHOLDERS CON CLAVES REALES ANTES DE USAR

# ═══ BLOQUE 1: NVIDIA NIM (PRIMARY) ═══
NVIDIA_API_KEY=REPLACE_WITH_YOUR_NVIDIA_API_KEY
# 2026-06-07: Qwen3-Coder 480B = coder primario; DeepSeek V4 Flash queda como pro/fallback rapido
NVIDIA_MODEL=qwen/qwen3-coder-480b-a35b-instruct
NVIDIA_PRO_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# ═══ BLOQUE 2: KIMI (PENDIENTE - obtener en platform.moonshot.cn) ═══
MOONSHOT_API_KEY=
KIMI_MODEL=kimi-k2-0711
KIMI_PRO_MODEL=moonshot-v1-128k

# ═══ BLOQUE 3: GLM / ZHIPU (CONFIGURADO 2026-06-22) ═══
ZHIPU_API_KEY=REPLACE_WITH_YOUR_ZHIPU_API_KEY
GLM_API_KEY=REPLACE_WITH_YOUR_GLM_API_KEY
GLM_MODEL=glm-4-flash
GLM_PRO_MODEL=glm-4-plus

# ═══ BLOQUE 4: DeepSeek directo (ACTUALIZADO 2026-06-22) ═══
DEEPSEEK_API_KEY=REPLACE_WITH_YOUR_DEEPSEEK_API_KEY
DEEPSEEK_MODEL=deepseek-v4-flash

# ═══ BLOQUE 5: Cloudflare Workers AI (fallback) ═══
# URL OpenAI-compatible confirmada activa con cfut_ token
CLOUDFLARE_AI_BASE_URL=https://api.cloudflare.com/client/v4/accounts/2b7d685bb38b0badcfb48e9d221f6e73/ai/v1
# 2026-06-26: token rotado por Tyr (reemplaza cfut_P94...)
CLOUDFLARE_API_TOKEN=REPLACE_WITH_YOUR_CLOUDFLARE_API_TOKEN
CLOUDFLARE_ACCOUNT_ID=2b7d685bb38b0badcfb48e9d221f6e73

# ═══ BLOQUE 6: Config Wabi-Sabi ═══
WABI_PROVIDER=glm
WABI_MODEL=glm-4-plus
WABI_ALLOW_CLOUD_PROVIDERS=1
WABI_LLM_PROVIDER_CLOUD_DEFAULT=1

# ═══ BLOQUE 7: Opcionales - CONFIGURADOS 2026-06-22 ═══
ANTHROPIC_API_KEY=
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
OPENAI_API_KEY=
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY

# --- 2026-06-22: NUEVOS PROVEEDORES ---
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_API_KEY
GOOGLE_STUDIO_API_KEY=REPLACE_WITH_YOUR_GOOGLE_STUDIO_API_KEY
GOOGLE_CLOUD_PROJECT=948678043613

# HIGGSFIELD (para Vibe Forge assets) — 2026-06-26: secret añadido
HIGGSFIELD_API_KEY=REPLACE_WITH_YOUR_HIGGSFIELD_API_KEY
HIGGSFIELD_SECRET=REPLACE_WITH_YOUR_HIGGSFIELD_SECRET

# --- 2026-06-26: cadena de proveedores actualizada (GLM PRIORITARIO) ---
# glm -> nvidia -> cloudflare -> deepseek -> groq -> openrouter -> ollama -> dry-run
WABI_PROVIDER_ORDER=glm,nvidia,cloudflare,deepseek,groq,openrouter,ollama,dry-run
# Cold start de ollama local en 8GB RAM puede exceder 180s
WABI_HTTP_TIMEOUT_S=420
# Modelo Cloudflare Workers AI explicito (alternativa chat general: @cf/meta/llama-3.3-70b-instruct-fp8-fast)
CLOUDFLARE_AI_MODEL=@cf/qwen/qwen2.5-coder-32b-instruct
# Alternativas NIM anotadas: moonshotai/kimi-k2-instruct (razonamiento general)

# --- Gumroad (2026-06-26: añadido desde HF AK.txt) ---
GUMROAD_APP_ID=REPLACE_WITH_YOUR_GUMROAD_APP_ID
GUMROAD_APP_SECRET=REPLACE_WITH_YOUR_GUMROAD_APP_SECRET
GUMROAD_ACCESS_TOKEN=REPLACE_WITH_YOUR_GUMROAD_ACCESS_TOKEN

# --- Stripe (2026-06-26: claves test reales desde HF AK.txt; webhook/price siguen pendientes) ---
STRIPE_RESTRICTED_KEY=REPLACE_WITH_YOUR_STRIPE_RESTRICTED_KEY
STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_ID_ANTI_IA=price_REPLACE_WITH_ANTI_IA_PRICE_ID
STRIPE_PRICE_ID_FACTCHECK=price_REPLACE_WITH_FACTCHECK_PRICE_ID
STRIPE_PRICE_ID_FACTCHECK_PRO=price_REPLACE_WITH_FACTCHECK_PRO_PRICE_ID