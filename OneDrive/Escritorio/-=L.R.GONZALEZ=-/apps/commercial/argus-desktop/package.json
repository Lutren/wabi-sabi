{
  "name": "argus-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Argus Desktop - companion shell for MEDIOEVO",
  "author": "L.R. Gonzalez",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 47847",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1 --port 47847",
    "postinstall": "node scripts/repair-workbox-terser.cjs",
    "cap:sync": "npx cap sync",
    "electron:dev": "npm run build && electron .",
    "electron:build:win": "npm run build && electron-builder --win --config electron-builder.json"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-python": "^6.1.7",
    "@uiw/react-codemirror": "^4.24.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.1.0"
  },
  "overrides": {
    "@rollup/plugin-terser": "1.0.0"
  }
}
