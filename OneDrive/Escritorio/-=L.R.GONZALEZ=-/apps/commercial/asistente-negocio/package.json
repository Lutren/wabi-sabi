{
  "name": "asistente-negocio-medioevo",
  "version": "1.0.0",
  "private": true,
  "description": "Asistente de Negocio MEDIOEVO public-safe: CRM ligero, voz, borradores y aprobacion humana.",
  "author": "L.R. Gonzalez",
  "license": "SEE LICENSE_EULA.md",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "electron .",
    "check": "node scripts/check-public-safe.cjs",
    "smoke:e2e-render": "node scripts/e2e-render-smoke.cjs",
    "preview": "node scripts/build-standalone-preview.cjs",
    "package:final": "node scripts/package-final-release.cjs",
    "build:win": "npm run check && electron-builder --win --config electron-builder.json",
    "build:mac": "npm run check && electron-builder --mac --config electron-builder.json",
    "pack:win": "npm run check && electron-builder --win --dir --config electron-builder.json",
    "pack:mac": "npm run check && electron-builder --mac --dir --config electron-builder.json"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
