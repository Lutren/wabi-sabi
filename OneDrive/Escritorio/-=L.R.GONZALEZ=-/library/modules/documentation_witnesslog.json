{
  "module_id": "documentation_witnesslog",
  "name": "Documentation WitnessLog",
  "version": "0.1.0",
  "fingerprint": "matrix-documentation-witnesslog-v0-1",
  "domain": "documentation.evidence",
  "purpose": "Make decisions durable through fichas, handoffs and append-only evidence.",
  "minimal_summary": "Document source, decision, hash, evidence, tests and residual risk before claiming closure.",
  "DO_deconstruction": ["find source", "capture hash or path", "extract decision", "separate certainty from inference"],
  "IOI_recompilation": ["write ficha", "write handoff", "append witness event when enabled", "link tests"],
  "primitives": ["ficha", "handoff", "WitnessLog", "fingerprint", "residual_R"],
  "inputs": ["artifact path", "decision", "test output", "gate result"],
  "outputs": ["markdown record", "JSON event", "handoff"],
  "invariants": ["no invented success", "records cite evidence", "append-only when logging"],
  "interfaces": {"files": ["COMMS/schemas/witness-log-event.schema.json", "qa_artifacts/witness_log/curador_seto_witnesslog.jsonl"]},
  "dependencies": ["observacionismo_core"],
  "compatible_modules": ["security_actiongate", "ioi_core", "duat_world_state"],
  "forbidden_combinations": ["history_rewrite", "unverified_done_status"],
  "safety_constraints": ["secret scan before public docs", "private routes scrubbed for public outputs"],
  "evidence_sources": ["COMMS/schemas/witness-log-event.schema.json", "docs/observacionismo/COMMS_L1_ACTIONGATE_BRIDGE_V0_1.md"],
  "examples": [{"input": "adapter implemented", "output": "tests plus handoff plus fingerprint"}],
  "tests": ["COMMS validator PASS", "secret scan count 0 for touched docs"],
  "decay_policy": "Review when WitnessLog schema changes.",
  "update_policy": "Update only after validator supports the new event shape.",
  "handoff_template": {"receiver": "Archivist", "include": ["artifact", "hash", "tests", "gate"], "gate": "REVIEW"}
}
