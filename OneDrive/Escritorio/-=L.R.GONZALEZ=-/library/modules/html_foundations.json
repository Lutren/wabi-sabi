{
  "module_id": "html_foundations",
  "name": "HTML Foundations",
  "version": "0.1.0",
  "fingerprint": "matrix-html-foundations-v0-1",
  "domain": "web.html",
  "purpose": "Provide minimal semantic HTML structure for local public-safe pages.",
  "minimal_summary": "Use semantic landmarks, accessible text, local assets and no private paths.",
  "DO_deconstruction": ["identify page purpose", "separate content from decoration", "check private asset risk"],
  "IOI_recompilation": ["create semantic skeleton", "attach accessible labels", "keep public copy low-claim"],
  "primitives": ["doctype", "main", "nav", "section", "button", "form", "alt text"],
  "inputs": ["page goal", "copy", "asset list"],
  "outputs": ["HTML skeleton", "accessibility checklist"],
  "invariants": ["no private paths", "no secret values", "no unsupported claims"],
  "interfaces": {"files": ["index.html", "docs/matrix/09_examples.md"]},
  "dependencies": [],
  "compatible_modules": ["web_ui_minimal", "security_actiongate", "ai_browser_security"],
  "forbidden_combinations": ["private_assets_export", "external_tracking_without_gate"],
  "safety_constraints": ["no hidden prompt injection in page copy", "no credential collection without gate"],
  "evidence_sources": ["docs/ai_browser/04_security_requirements.md", "docs/matrix/09_examples.md"],
  "examples": [{"input": "landing page", "output": "header, main, CTA, footer with low-claim copy"}],
  "tests": ["render locally", "scan for private paths and secrets"],
  "decay_policy": "Review when public web requirements change.",
  "update_policy": "Update through UI/security review, not aesthetic trend alone.",
  "handoff_template": {"receiver": "Builder", "include": ["semantic sections", "copy boundaries", "asset rules"], "gate": "REVIEW"}
}
