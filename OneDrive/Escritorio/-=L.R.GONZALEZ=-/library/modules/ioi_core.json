{
  "module_id": "ioi_core",
  "name": "Ingenieria Observacionista Inversa Core",
  "version": "0.1.0",
  "fingerprint": "matrix-ioi-core-v0-1",
  "domain": "reasoning.recompilation",
  "purpose": "Recompile a deconstructed stimulus into minimal operational steps for agents.",
  "minimal_summary": "Convert DO output into a scoped plan: modules, workpacks, tests, gate and handoff.",
  "DO_deconstruction": ["read DO fields", "identify missing evidence", "detect agent language needed"],
  "IOI_recompilation": ["select minimal modules", "generate workpack", "assign department", "define close criteria"],
  "primitives": ["workpack", "department head", "close criteria", "residual R"],
  "inputs": ["DO result", "available modules", "constraints", "requested output"],
  "outputs": ["delegation packet", "module list", "test list", "handoff"],
  "invariants": ["workpack has owner", "tests are explicit", "blocked actions are named"],
  "interfaces": {"files": ["docs/matrix/05_delegation_protocol.md"], "comms": ["handoff_contract"]},
  "dependencies": ["observacionismo_core"],
  "compatible_modules": ["documentation_witnesslog", "security_actiongate"],
  "forbidden_combinations": ["unscoped_autonomy", "bulk_context_load"],
  "safety_constraints": ["no autonomous external actions", "no silent writes outside assigned scope"],
  "evidence_sources": ["docs/matrix/01_architecture.md", "apps/local/wabi-sabi/docs/ARCHITECTURE.md"],
  "examples": [{"input": "Create landing page", "output": "web_ui_minimal plus security_actiongate workpack"}],
  "tests": ["validate workpack has goal, modules, forbidden_actions and tests"],
  "decay_policy": "Review after agent registry changes.",
  "update_policy": "Update with new validated department roles only.",
  "handoff_template": {"receiver": "DepartmentHead", "include": ["goal", "modules", "scope", "tests"], "gate": "REVIEW"}
}
