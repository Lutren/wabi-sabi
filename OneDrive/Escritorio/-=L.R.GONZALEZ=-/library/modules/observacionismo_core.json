{
  "module_id": "observacionismo_core",
  "name": "Observacionismo Core",
  "version": "0.1.0",
  "fingerprint": "matrix-observacionismo-core-v0-1",
  "domain": "reasoning.observacionismo",
  "purpose": "Separate observation, claim, evidence, falsifier, residue and action before execution.",
  "minimal_summary": "Use evidence before action: observe, document, verify, act only through gate, then handoff.",
  "DO_deconstruction": ["separate stimulus from claim", "label evidence and uncertainty", "identify falsifiers", "estimate residual R"],
  "IOI_recompilation": ["turn claim into testable workpack", "attach evidence refs", "choose gate", "compile handoff"],
  "primitives": ["ObservationEnvelope", "claim_level", "falsifier", "residue", "ActionGate"],
  "inputs": ["user stimulus", "source path", "evidence list", "risk flags"],
  "outputs": ["ObservationEnvelope draft", "gate proposal", "handoff summary"],
  "invariants": ["no claim without evidence", "no action without gate", "uncertainty is preserved"],
  "interfaces": {"files": ["COMMS/schemas/observation-envelope.schema.json"], "comms": ["ObservationEnvelope", "ActionGate"]},
  "dependencies": [],
  "compatible_modules": ["ioi_core", "security_actiongate", "documentation_witnesslog"],
  "forbidden_combinations": ["public_claim_without_falsifier", "private_canon_bulk_load"],
  "safety_constraints": ["strong medical, physical or social claims remain BLOCK", "private paths are not exported"],
  "evidence_sources": ["docs/observacionismo/COMMS_L1_ACTIONGATE_BRIDGE_V0_1.md", "COMMS/schemas/observation-envelope.schema.json"],
  "examples": [{"input": "Build a tool", "output": "ObservationEnvelope plus REVIEW gate until scope is explicit"}],
  "tests": ["python COMMS/tools/validate_seto_comms.py --json --fail-on-errors"],
  "decay_policy": "Review when COMMS schemas change.",
  "update_policy": "Update only with validated schema or bridge changes.",
  "handoff_template": {"receiver": "Auditor", "include": ["claim", "evidence", "falsifiers", "gate"], "gate": "REVIEW"}
}
