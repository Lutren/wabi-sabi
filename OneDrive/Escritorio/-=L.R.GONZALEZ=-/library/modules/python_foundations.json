{
  "module_id": "python_foundations",
  "name": "Python Foundations",
  "version": "0.1.0",
  "fingerprint": "matrix-python-foundations-v0-1",
  "domain": "programming.python",
  "purpose": "Provide minimal Python primitives for local scripts, validators and adapters.",
  "minimal_summary": "Prefer stdlib, pure functions, explicit paths, JSON output and focused tests.",
  "DO_deconstruction": ["identify inputs and outputs", "separate IO from pure logic", "find unsafe filesystem operations"],
  "IOI_recompilation": ["write small functions", "add CLI only if useful", "validate with py_compile and pytest"],
  "primitives": ["Path", "json", "argparse", "dataclass", "unittest", "pytest"],
  "inputs": ["local files", "JSON", "CLI args"],
  "outputs": ["JSON report", "validated artifact", "exit code"],
  "invariants": ["no network by default", "no destructive recursion", "paths are explicit"],
  "interfaces": {"files": ["tools/matrix/validate_library.py"], "cli": ["python tools/matrix/validate_library.py --json"]},
  "dependencies": [],
  "compatible_modules": ["security_actiongate", "documentation_witnesslog"],
  "forbidden_combinations": ["unsafe_shell_delete", "secret_dumping"],
  "safety_constraints": ["do not hide failures", "do not write outside allowed path"],
  "evidence_sources": ["claudio/adapters/duat_readonly_adapter.py", "tests/test_duat_readonly_adapter.py"],
  "examples": [{"input": "Validate JSON modules", "output": "stdlib validator with nonzero exit on errors"}],
  "tests": ["python -m py_compile tools/matrix/validate_library.py", "python tools/matrix/validate_library.py --json"],
  "decay_policy": "Review when Python version or validator contract changes.",
  "update_policy": "Keep dependency-free unless a gate approves otherwise.",
  "handoff_template": {"receiver": "Builder", "include": ["paths", "commands", "expected JSON"], "gate": "REVIEW"}
}
