{
  "module_id": "security_actiongate",
  "name": "Security ActionGate",
  "version": "0.1.0",
  "fingerprint": "matrix-security-actiongate-v0-1",
  "domain": "security.gates",
  "purpose": "Block risky actions unless evidence, scope and rollback are explicit.",
  "minimal_summary": "APPROVE local safe actions, REVIEW scoped writes, BLOCK secrets, deletion, publication and strong claims.",
  "DO_deconstruction": ["identify destructive verbs", "identify external action", "identify secret boundary", "classify claim strength"],
  "IOI_recompilation": ["return gate decision", "name risk flags", "require evidence", "define rollback"],
  "primitives": ["APPROVE", "REVIEW", "BLOCK", "risk_flags", "required_evidence"],
  "inputs": ["task text", "paths", "claim level", "action type"],
  "outputs": ["ActionGate decision", "blocked actions", "post validation"],
  "invariants": ["secrets are BLOCK", "publication is BLOCK until specific gate", "private canon is not exported"],
  "interfaces": {"files": ["COMMS/schemas/action-gate.schema.json", "apps/local/wabi-sabi/wabi_sabi/core/gate.py"]},
  "dependencies": [],
  "compatible_modules": ["observacionismo_core", "documentation_witnesslog", "ai_browser_security"],
  "forbidden_combinations": ["bypass_gate", "silent_external_action"],
  "safety_constraints": ["no network fetch without gate", "no delete/move without manifest and approval"],
  "evidence_sources": ["COMMS/schemas/action-gate.schema.json", "apps/local/wabi-sabi/wabi_sabi/core/gate.py"],
  "examples": [{"input": "publish landing", "output": "BLOCK until target, scan and approval exist"}],
  "tests": ["python COMMS/tools/validate_seto_comms.py --json --fail-on-errors"],
  "decay_policy": "Review whenever gate schema or safety policy changes.",
  "update_policy": "Update conservatively; default new risky verbs to BLOCK.",
  "handoff_template": {"receiver": "SecurityGate", "include": ["risk_flags", "evidence", "rollback"], "gate": "REVIEW"}
}
