{
  "module_id": "web_ui_minimal",
  "name": "Web UI Minimal",
  "version": "0.1.0",
  "fingerprint": "matrix-web-ui-minimal-v0-1",
  "domain": "web.ui",
  "purpose": "Create small, legible, responsive interfaces without generic dashboard bloat.",
  "minimal_summary": "One primary task per surface, dense but readable controls, stable dimensions and visible evidence.",
  "DO_deconstruction": ["find core user action", "remove ornamental sections", "identify evidence panel"],
  "IOI_recompilation": ["layout main task first", "add controls by function", "verify mobile and desktop fit"],
  "primitives": ["topbar", "panel", "tabs", "buttons", "status chip", "evidence list"],
  "inputs": ["workflow", "state", "actions", "evidence"],
  "outputs": ["UI structure", "responsive checklist", "state map"],
  "invariants": ["no card inside card", "no text overflow", "no decorative clutter"],
  "interfaces": {"files": ["apps/local/wabi-sabi/README.md", "docs/matrix/09_examples.md"]},
  "dependencies": ["html_foundations"],
  "compatible_modules": ["security_actiongate", "documentation_witnesslog"],
  "forbidden_combinations": ["marketing_hero_for_tool_surface", "private_asset_export"],
  "safety_constraints": ["public UI must avoid private runtime detail", "external publish remains gated"],
  "evidence_sources": ["apps/local/wabi-sabi/README.md", "docs/product/COMMERCIAL_AGENT_PUBLICATION_MATRIX_2026-05-02.md"],
  "examples": [{"input": "Mission Control panel", "output": "status, evidence, actions, gate footer"}],
  "tests": ["manual screenshot review", "text overflow check", "secret/path scan"],
  "decay_policy": "Review when design system or product surface changes.",
  "update_policy": "Update with real UI evidence and not only preference.",
  "handoff_template": {"receiver": "Builder", "include": ["layout", "states", "responsive checks"], "gate": "REVIEW"}
}
