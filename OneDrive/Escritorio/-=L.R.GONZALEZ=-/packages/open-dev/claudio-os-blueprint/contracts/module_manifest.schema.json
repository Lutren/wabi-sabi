{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medioevo.local/schemas/brain_os/module_manifest.schema.json",
  "title": "Brain OS Module Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "owner",
    "purpose",
    "inputs",
    "outputs",
    "states",
    "risk",
    "cost",
    "gates",
    "evidence_required",
    "witness",
    "recovery",
    "interfaces"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 10
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/io_item"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/io_item"
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "observando",
          "planificando",
          "ejecutando",
          "renderizando",
          "qa",
          "esperando",
          "atascado",
          "requiere_aprobacion",
          "listo",
          "fallido"
        ]
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "irreversible", "external_effects"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "irreversible": {
          "type": "boolean"
        },
        "external_effects": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "paid_api"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["local", "free_manual", "approval_required", "disabled"]
        },
        "paid_api": {
          "type": "boolean"
        },
        "budget_hint": {
          "type": "string"
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "evidence",
          "psi",
          "cost",
          "irreversible",
          "publish",
          "voice_clone",
          "browser_manifest",
          "blocked_actions",
          "human_approval"
        ]
      }
    },
    "evidence_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "witness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["log", "include_payload_summary"],
      "properties": {
        "log": {
          "type": "string",
          "minLength": 1
        },
        "include_payload_summary": {
          "type": "boolean"
        }
      }
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["on_hold", "on_degrade", "on_failure"],
      "properties": {
        "on_hold": {
          "type": "string",
          "minLength": 1
        },
        "on_degrade": {
          "type": "string",
          "minLength": 1
        },
        "on_failure": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "interfaces": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cli": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "http": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "minProperties": 1
    }
  },
  "$defs": {
    "io_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

