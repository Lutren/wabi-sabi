#!/usr/bin/env bash
set -euo pipefail

lb config \
  --distribution bookworm \
  --archive-areas "main contrib non-free-firmware" \
  --binary-images iso-hybrid \
  --iso-volume "CLAUDIO_OS" \
  --iso-application "ClaudioOS v0.1" \
  --debian-installer false \
  --bootappend-live "boot=live components hostname=claudio-os username=claudio"

