[Unit]
Description=Claudio Guardian Observacionista
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/claudio/guardian/guardian.py
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/log/claudio

[Install]
WantedBy=multi-user.target

