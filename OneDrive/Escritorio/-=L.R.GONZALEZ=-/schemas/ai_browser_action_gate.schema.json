{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.ai_browser.action_gate.v1",
  "title": "AI Browser ActionGate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "decision",
    "operation",
    "allowed_operations",
    "network_mode",
    "target_url",
    "allowed_domains",
    "reason"
  ],
  "properties": {
    "schema": {
      "const": "ai_browser.action_gate.v1"
    },
    "decision": {
      "type": "string",
      "enum": ["APPROVE", "REVIEW", "BLOCK"]
    },
    "operation": {
      "const": "remote_stub"
    },
    "allowed_operations": {
      "type": "array",
      "contains": {
        "const": "remote_stub"
      },
      "items": {
        "type": "string"
      }
    },
    "network_mode": {
      "const": "stub_only"
    },
    "target_url": {
      "type": "string",
      "minLength": 1
    },
    "allowed_domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
