{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.ai_browser.ghostgate_memory_decision.v1",
  "title": "AI Browser GhostGate Memory Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source_input",
    "source_snapshot_hash",
    "decision",
    "memory_allowed",
    "canon_allowed",
    "risk_flags",
    "reasons",
    "required_next_gate"
  ],
  "properties": {
    "schema": {
      "const": "ai_browser.ghostgate_memory_decision.v1"
    },
    "source_input": {
      "type": "string",
      "minLength": 1
    },
    "source_snapshot_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "APPROVE",
        "REVIEW",
        "BLOCK"
      ]
    },
    "memory_allowed": {
      "type": "boolean"
    },
    "canon_allowed": {
      "type": "boolean"
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "required_next_gate": {
      "type": "string"
    }
  }
}
