{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.ai_browser.secret_scan_report.v1",
  "title": "AI Browser Secret Scan Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "snapshot_hash",
    "scanned_artifacts",
    "redaction",
    "findings",
    "action_gate",
    "notes",
    "report_hash"
  ],
  "properties": {
    "schema": {
      "const": "ai_browser.secret_scan_report.v1"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "REVIEW", "BLOCK"]
    },
    "snapshot_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "scanned_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_like_content_redacted",
        "secret_redaction_count",
        "redaction_token"
      ],
      "properties": {
        "secret_like_content_redacted": {
          "type": "boolean"
        },
        "secret_redaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "redaction_token": {
          "const": "[REDACTED_SECRET_LIKE_CONTENT]"
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "action_gate": {
      "type": "string",
      "enum": ["APPROVE", "REVIEW", "BLOCK"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "report_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
